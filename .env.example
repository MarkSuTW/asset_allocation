# CORS origins allowed to call the API (comma-separated, or * for any)
# For Tailscale multi-device access, use * — Tailscale ACLs handle the security
ALLOWED_ORIGINS=*

# Choose at least one provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional Anthropic fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Google Drive backup ─────────────────────────────────────────────────────
# Path to the service-account JSON key. Store OUTSIDE the project directory
# (e.g. C:\Secrets\gdrive_key.json) and NEVER commit it to git.
GDRIVE_CREDENTIALS_PATH=C:\Secrets\gdrive_key.json

# ID of the Drive folder to upload into (copy from the folder URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID>)
GDRIVE_FOLDER_ID=

# SQLite file to back up (default: wealth.db)
DB_PATH=wealth.db

# Local staging directory (default: backups/)
BACKUP_LOCAL_DIR=backups

# How many Drive copies to keep before the oldest is deleted (default: 7)
GDRIVE_KEEP_VERSIONS=7

# Set to "false" to keep the local .gz file after upload (default: true = delete)
GDRIVE_DELETE_LOCAL=true
